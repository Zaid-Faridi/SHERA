# SHEra Backend Environment Variables
# Copy this file to .env and update the values for your local setup:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port for the Node.js API (default: 5001)
PORT=5001

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local MongoDB (default)
MONGODB_URI=mongodb://127.0.0.1:27017/pcos-pcod-app

# MongoDB Atlas example (uncomment and replace with your connection string)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pcos-pcod-app?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret used to sign and verify JWT tokens.
# Use a long random string in production — never commit the real value.
JWT_SECRET=your_jwt_secret_here_change_in_production

# -----------------------------------------------------------------------------
# Other services (no .env required — configured in code)
# -----------------------------------------------------------------------------
# Frontend (Vite):  http://localhost:3333  — see frontend/vite.config.js
# AI Engine (Flask): http://localhost:5000  — see pcos-pcod-ai-project/app.py
#
# This project does not use third-party API keys (OpenAI, Google Maps, etc.).
